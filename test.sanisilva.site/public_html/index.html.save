<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pulsar — Data That Moves</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,900;1,700&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:root {
  --cream: #f5f0e8;
  --ink: #0f0e0c;
  --red: #d63b2f;
  --gold: #c8952a;
  --mid: #8a8070;
}
body { background: var(--cream); color: var(--ink); font-family: 'Space Mono', monospace; line-height: 1.5; cursor: crosshair; }

/* TICKER */
.ticker { background: var(--ink); color: var(--cream); overflow: hidden; padding: .5rem 0; font-size: .7rem; letter-spacing: .08em; }
.ticker-inner { display: flex; gap: 4rem; animation: ticker 30s linear infinite; white-space: nowrap; }
.ticker-inner b { color: var(--gold); }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* HEADER */
header { border-bottom: 3px solid var(--ink); }
.header-top { display: flex; align-items: stretch; border-bottom: 1px solid var(--ink); }
.header-date { flex: 1; padding: .6rem 1.5rem; font-size: .7rem; letter-spacing: .1em; text-transform: uppercase; border-right: 1px solid var(--ink); display: flex; align-items: center; }
.header-tagline { flex: 1; padding: .6rem 1.5rem; font-size: .7rem; letter-spacing: .1em; text-transform: uppercase; text-align: right; display: flex; align-items: center; justify-content: flex-end; }
.header-logo-row { padding: 1.5rem 2rem; text-align: center; border-bottom: 1px solid var(--ink); }
.logo-main { font-family: 'Playfair Display', serif; font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 900; line-height: .95; letter-spacing: -.02em; }
.logo-main em { font-style: italic; color: var(--red); }
.logo-sub { font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; color: var(--mid); margin-top: .4rem; }
.header-nav { display: flex; border-top: 1px solid var(--ink); }
.header-nav a { flex: 1; text-align: center; padding: .8rem; font-size: .7rem; letter-spacing: .12em; text-transform: uppercase; text-decoration: none; color: var(--ink); border-right: 1px solid var(--ink); transition: background .15s, color .15s; }
.header-nav a:last-child { border-right: none; }
.header-nav a:hover { background: var(--ink); color: var(--cream); }
.header-nav a.active { background: var(--red); color: var(--cream); }

/* MAIN GRID */
main { display: grid; grid-template-columns: 1fr 2px 2fr 2px 1fr; min-height: 80vh; }
.col-divider { background: var(--ink); }
.col-left { padding: 2rem 1.5rem; }
.col-center { padding: 0; }
.col-right { padding: 2rem 1.5rem; }

/* SIDE SECTIONS */
.side-section { margin-bottom: 2.5rem; border-bottom: 1px solid var(--ink); padding-bottom: 2rem; }
.side-section:last-child { border-bottom: none; }
.side-label { font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--red); margin-bottom: .8rem; display: flex; align-items: center; gap: .5rem; }
.side-label::after { content: ''; flex: 1; height: 1px; background: var(--red); }

/* HERO */
.hero-feature { border-bottom: 2px solid var(--ink); padding: 3rem 3rem 2.5rem; }
.hero-kicker { font-size: .65rem; letter-spacing: .2em; text-transform: uppercase; background: var(--red); color: var(--cream); display: inline-block; padding: .2rem .6rem; margin-bottom: 1.2rem; }
.hero-headline { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900; line-height: 1.05; letter-spacing: -.02em; margin-bottom: 1.2rem; }
.hero-headline i { font-style: italic; color: var(--red); }
.hero-dek { font-size: .85rem; color: var(--mid); max-width: 480px; margin-bottom: 2rem; line-height: 1.7; }
.hero-byline { font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; color: var(--mid); border-top: 1px solid var(--ink); padding-top: 1rem; }
.hero-byline b { color: var(--ink); }

/* BIG NUMBERS */
.big-number-block { display: grid; grid-template-columns: 1fr 1fr 1fr; border-bottom: 2px solid var(--ink); }
.big-num { padding: 1.5rem; border-right: 1px solid var(--ink); text-align: center; }
.big-num:last-child { border-right: none; }
.big-num .n { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 900; line-height: 1; }
.big-num .n span { color: var(--red); }
.big-num .l { font-size: .6rem; letter-spacing: .12em; text-transform: uppercase; color: var(--mid); margin-top: .3rem; }

/* SUB ARTICLES */
.sub-articles { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--ink); }
.article-card { padding: 1.5rem; border-right: 1px solid var(--ink); transition: background .2s; }
.article-card:last-child { border-right: none; }
.article-card:hover { background: rgba(15,14,12,.04); }
.article-card .kicker { font-size: .6rem; letter-spacing: .15em; text-transform: uppercase; color: var(--gold); margin-bottom: .5rem; }
.article-card h3 { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 900; line-height: 1.2; margin-bottom: .5rem; }
.article-card p { font-size: .78rem; color: var(--mid); line-height: 1.6; }

/* PRICING TABLE */
.price-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
.price-table th { font-size: .6rem; letter-spacing: .12em; text-transform: uppercase; padding: .5rem .4rem; border-bottom: 2px solid var(--ink); text-align: left; }
.price-table td { font-size: .75rem; padding: .6rem .4rem; border-bottom: 1px solid rgba(15,14,12,.15); vertical-align: top; }
.price-table tr:hover td { background: rgba(15,14,12,.04); }
.plan { font-weight: 700; }
.price { color: var(--red); font-weight: 700; }
.popular { background: var(--red); color: var(--cream); padding: .1rem .4rem; font-size: .55rem; letter-spacing: .1em; }

/* BUTTONS */
.btn-submit { background: var(--ink); color: var(--cream); border: none; padding: .9rem 2.5rem; font-family: 'Space Mono', monospace; font-size: .8rem; letter-spacing: .08em; cursor: crosshair; transition: background .2s; display: inline-block; text-decoration: none; }
.btn-submit:hover { background: var(--red); }
.btn-outline { background: transparent; color: var(--ink); border: 2px solid var(--ink); padding: .85rem 2.5rem; font-family: 'Space Mono', monospace; font-size: .8rem; letter-spacing: .08em; cursor: crosshair; transition: all .2s; text-decoration: none; display: inline-block; }
.btn-outline:hover { background: var(--ink); color: var(--cream); }

/* NEWSLETTER */
.nl-banner { background: var(--ink); color: var(--cream); padding: 2rem 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; border-top: 3px double var(--gold); flex-wrap: wrap; }
.nl-label { font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: .3rem; }
.nl-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 900; }
.nl-form { display: flex; }
.nl-form input { background: rgba(245,240,232,.08); border: 1px solid rgba(245,240,232,.2); border-right: none; padding: .7rem 1.2rem; font-family: 'Space Mono', monospace; font-size: .8rem; color: var(--cream); outline: none; min-width: 240px; }
.nl-form input::placeholder { color: rgba(245,240,232,.4); }
.nl-form input:focus { border-color: var(--gold); }
.nl-form button { background: var(--red); color: var(--cream); border: 1px solid var(--red); padding: .7rem 1.5rem; font-family: 'Space Mono', monospace; font-size: .75rem; letter-spacing: .08em; cursor: crosshair; transition: background .2s; }
.nl-form button:hover { background: #b83025; }

/* FORMS ZONE */
.forms-zone { border-top: 3px solid var(--ink); display: grid; grid-template-columns: 1fr 1fr; }
.form-panel { padding: 3rem; border-right: 2px solid var(--ink); }
.form-panel:last-child { border-right: none; }
.form-panel-label { font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--red); margin-bottom: 1.5rem; display: flex; align-items: center; gap: .6rem; }
.form-panel-label::before { content: '▶'; font-size: .5rem; }
.form-panel h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 900; line-height: 1.1; margin-bottom: 1rem; }
.form-panel > p { font-size: .8rem; color: var(--mid); margin-bottom: 2rem; line-height: 1.6; }
.field { margin-bottom: 1.2rem; }
.field label { display: block; font-size: .6rem; letter-spacing: .12em; text-transform: uppercase; margin-bottom: .4rem; color: var(--mid); }
.field input, .field select, .field textarea { width: 100%; background: transparent; border: none; border-bottom: 2px solid var(--ink); padding: .5rem 0; font-family: 'Space Mono', monospace; font-size: .85rem; color: var(--ink); outline: none; transition: border-color .2s; }
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(--red); }
.field textarea { resize: vertical; min-height: 80px; }
select option { background: var(--cream); }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.check-group { display: flex; align-items: flex-start; gap: .7rem; margin-bottom: 1.5rem; }
.check-group input[type=checkbox] { margin-top: .2rem; accent-color: var(--red); cursor: pointer; }
.check-group label { font-size: .75rem; color: var(--mid); cursor: pointer; line-height: 1.4; }

/* FOOTER */
footer { border-top: 3px solid var(--ink); display: grid; grid-template-columns: 2fr 2px 1fr 2px 1fr 2px 1fr; }
.footer-divider { background: var(--ink); }
.footer-col { padding: 2.5rem 2rem; }
.footer-brand .logo-main { font-size: 2.5rem; }
.footer-brand p { font-size: .75rem; color: var(--mid); margin-top: .8rem; line-height: 1.6; }
.footer-col h5 { font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--red); margin-bottom: 1.2rem; }
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: .6rem; }
.footer-col ul a { font-size: .75rem; color: var(--mid); text-decoration: none; transition: color .15s; }
.footer-col ul a:hover { color: var(--ink); }
.footer-bottom { background: var(--ink); color: var(--cream); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; font-size: .65rem; letter-spacing: .08em; }
.footer-bottom span { color: var(--gold); }

/* TOAST */
.toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--ink); color: var(--cream); border-left: 4px solid var(--red); padding: .9rem 2rem; font-size: .8rem; letter-spacing: .04em; opacity: 0; transition: all .4s; z-index: 999; white-space: nowrap; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* RESPONSIVE */
@media (max-width: 900px) {
  main { grid-template-columns: 1fr; }
  .col-divider { display: none; }
  .col-left, .col-right { border-top: 2px solid var(--ink); }
  .forms-zone { grid-template-columns: 1fr; }
  .form-panel { border-right: none; border-bottom: 2px solid var(--ink); }
  footer { grid-template-columns: 1fr; }
  .footer-divider { display: none; }
  .footer-col { border-bottom: 1px solid var(--ink); }
  .sub-articles { grid-template-columns: 1fr; }
  .header-nav a { font-size: .55rem; padding: .6rem .3rem; }
  .field-row { grid-template-columns: 1fr; }
  .nl-banner { padding: 2rem 1.5rem; }
}
</style>
</head>
<body>

<div class="ticker">
  <div class="ticker-inner">
    <span>SESSIONS TRACKED TODAY &nbsp;<b>2,847,392</b></span>
    <span>CONVERSION RATE AVG &nbsp;<b>+3.8%</b></span>
    <span>UPTIME &nbsp;<b>99.97%</b></span>
    <span>ACTIVE USERS NOW &nbsp;<b>41,209</b></span>
    <span>NEW SIGNUPS TODAY &nbsp;<b>847</b></span>
    <span>AVG SESSION DURATION &nbsp;<b>4m 12s</b></span>
    <span>SESSIONS TRACKED TODAY &nbsp;<b>2,847,392</b></span>
    <span>CONVERSION RATE AVG &nbsp;<b>+3.8%</b></span>
    <span>UPTIME &nbsp;<b>99.97%</b></span>
    <span>ACTIVE USERS NOW &nbsp;<b>41,209</b></span>
    <span>NEW SIGNUPS TODAY &nbsp;<b>847</b></span>
    <span>AVG SESSION DURATION &nbsp;<b>4m 12s</b></span>
  </div>
</div>

<header>
  <div class="header-top">
    <div class="header-date">Monday, February 23, 2026 &nbsp;·&nbsp; Vol. IV, Issue 12</div>
    <div class="header-tagline">The Analytics Platform for Product Teams</div>
  </div>
  <div class="header-logo-row">
    <div class="logo-main"><em>Pulsar</em></div>
    <div class="logo-sub">Real-time Behavioral Intelligence &nbsp;·&nbsp; Est. 2022</div>
  </div>
  <nav class="header-nav">
    <a href="#" class="active">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#about">About</a>
    <a href="#contact-form">Get a Demo</a>
    <a href="#signup-form">Sign Up Free</a>
    <a href="#newsletter">Newsletter</a>
  </nav>
</header>

<main>
  <!-- LEFT -->
  <div class="col-left">
    <div class="side-section">
      <div class="side-label">Platform Stats</div>
      <div style="font-size:.75rem;color:var(--mid);line-height:2.2;">
        <div style="display:flex;justify-content:space-between;border-bottom:1px dashed rgba(15,14,12,.2);padding:.2rem 0;"><span>Companies</span><b style="color:var(--ink);">12,400+</b></div>
        <div style="display:flex;justify-content:space-between;border-bottom:1px dashed rgba(15,14,12,.2);padding:.2rem 0;"><span>Sessions/day</span><b style="color:var(--ink);">2M+</b></div>
        <div style="display:flex;justify-content:space-between;border-bottom:1px dashed rgba(15,14,12,.2);padding:.2rem 0;"><span>Script size</span><b style="color:var(--ink);">3 kb</b></div>
        <div style="display:flex;justify-content:space-between;border-bottom:1px dashed rgba(15,14,12,.2);padding:.2rem 0;"><span>Integrations</span><b style="color:var(--ink);">100+</b></div>
        <div style="display:flex;justify-content:space-between;padding:.2rem 0;"><span>Uptime SLA</span><b style="color:var(--red);">99.9%</b></div>
      </div>
    </div>
    <div class="side-section">
      <div class="side-label">Core Features</div>
      <div style="font-size:.78rem;line-height:1.8;">
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">📊 &nbsp;Real-Time Dashboards</p>
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">🧠 &nbsp;Predictive Funnels</p>
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">🗺️ &nbsp;Heatmaps & Recordings</p>
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">⚡ &nbsp;1-Minute SDK Setup</p>
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">🔒 &nbsp;GDPR / SOC 2 Ready</p>
        <p style="padding:.5rem 0;border-bottom:1px solid rgba(15,14,12,.1);">🔗 &nbsp;100+ Integrations</p>
        <p style="padding:.5rem 0;">📱 &nbsp;Mobile SDK (iOS, Android)</p>
      </div>
    </div>
    <div class="side-section">
      <div class="side-label">In The Press</div>
      <blockquote style="font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;line-height:1.5;">"Pulsar replaced four tools for us and cost half as much."</blockquote>
      <p style="font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-top:.8rem;">— TechCrunch, Jan 2026</p>
    </div>
    <div class="side-section">
      <div class="side-label">Integrations</div>
      <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Slack</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">HubSpot</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Salesforce</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Segment</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Amplitude</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Mixpanel</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">BigQuery</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">Snowflake</span>
        <span style="font-size:.65rem;border:1px solid var(--ink);padding:.2rem .5rem;">+91 more</span>
      </div>
    </div>
  </div>

  <div class="col-divider"></div>

  <!-- CENTER -->
  <div class="col-center">
    <div class="hero-feature">
      <div class="hero-kicker">New Platform Release</div>
      <h1 class="hero-headline">See What Your Users<br><i>Actually</i> Do,<br>Not What They Say.</h1>
      <p class="hero-dek">Pulsar captures every scroll, click, and rage-tap in real time — then surfaces the insights that matter before you even think to ask. Drop in one script tag. See everything.</p>
      <div style="display:flex;gap:1rem;margin-bottom:2rem;flex-wrap:wrap;">
        <a href="#signup-form" class="btn-submit">→ Start Free Trial</a>
        <a href="#contact-form" class="btn-outline">Book a Demo</a>
      </div>
      <div class="hero-byline">By <b>The Pulsar Team</b> &nbsp;·&nbsp; Published Feb 23, 2026 &nbsp;·&nbsp; 3 min read</div>
    </div>
    <div class="big-number-block">
      <div class="big-num"><div class="n">12<span>k</span></div><div class="l">Teams Using Pulsar</div></div>
      <div class="big-num"><div class="n">3<span>kb</span></div><div class="l">Script Footprint</div></div>
      <div class="big-num"><div class="n">2<span>M+</span></div><div class="l">Sessions Per Day</div></div>
    </div>
    <div class="sub-articles" id="about">
      <div class="article-card">
        <div class="kicker">Our Story</div>
        <h3>Built by ex-Google engineers who got sick of bad data</h3>
        <p>Founded in Austin in 2022. We raised $14M Series A and built the tool we always wished existed — fast, honest, and cheap enough that small teams can actually use it.</p>
      </div>
      <div class="article-card">
        <div class="kicker">Why Pulsar</div>
        <h3>Your current analytics stack lies to you</h3>
        <p>Pageviews are vanity. Pulsar shows you behavioral truth — where users hesitate, where they drop, and who's about to churn, 72 hours before it happens.</p>
      </div>
    </div>
    <div style="padding:2rem;">
      <div style="font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;">Reader Testimonials</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
        <div style="border-left:3px solid var(--red);padding-left:1rem;">
          <p style="font-family:'Playfair Display',serif;font-size:.95rem;font-style:italic;line-height:1.5;">"We found a $200k/month leak in our funnel in the first week."</p>
          <p style="font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;color:var(--mid);margin-top:.5rem;">— Sara K., Head of Product @ Forma</p>
        </div>
        <div style="border-left:3px solid var(--gold);padding-left:1rem;">
          <p style="font-family:'Playfair Display',serif;font-size:.95rem;font-style:italic;line-height:1.5;">"Replaced Hotjar, FullStory, and Heap. Cut our tool spend by 60%."</p>
          <p style="font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;color:var(--mid);margin-top:.5rem;">— Marcus R., CTO @ Verdo Labs</p>
        </div>
      </div>
    </div>
  </div>

  <div class="col-divider"></div>

  <!-- RIGHT -->
  <div class="col-right" id="pricing">
    <div class="side-section">
      <div class="side-label">Pricing Index</div>
      <table class="price-table">
        <thead><tr><th>Plan</th><th>Sessions</th><th>$/mo</th></tr></thead>
        <tbody>
          <tr><td class="plan">Starter</td><td>5,000</td><td class="price">Free</td></tr>
          <tr style="background:rgba(214,59,47,.05);"><td class="plan">Growth <span class="popular">HOT</span></td><td>100k</td><td class="price">$79</td></tr>
          <tr><td class="plan">Scale</td><td>1M</td><td class="price">$249</td></tr>
          <tr><td class="plan">Enterprise</td><td>∞</td><td class="price">Custom</td></tr>
        </tbody>
      </table>
      <p style="font-size:.65rem;color:var(--mid);margin-top:.8rem;font-style:italic;">All plans include 14-day free trial. Annual billing saves 20%.</p>
    </div>
    <div class="side-section">
      <div class="side-label">Growth Plan Includes</div>
      <div style="font-size:.75rem;line-height:1.9;color:var(--mid);">
        <p>✓ &nbsp;Full heatmaps & recordings</p>
        <p>✓ &nbsp;Predictive churn alerts</p>
        <p>✓ &nbsp;Unlimited projects</p>
        <p>✓ &nbsp;1-year data retention</p>
        <p>✓ &nbsp;Funnel & cohort analysis</p>
        <p>✓ &nbsp;Priority email support</p>
        <p>✓ &nbsp;API access</p>
        <p style="text-decoration:line-through;">✗ &nbsp;SSO (Enterprise only)</p>
        <p style="text-decoration:line-through;">✗ &nbsp;On-prem deploy</p>
      </div>
    </div>
    <div class="side-section">
      <div class="side-label">Contact</div>
      <p style="font-size:.75rem;color:var(--mid);line-height:1.7;margin-bottom:1rem;">Questions? Our team replies within 2 hours on business days.</p>
      <p style="font-size:.75rem;margin-bottom:.4rem;">📧 &nbsp;<a href="mailto:hello@pulsar.io" style="color:var(--red);text-decoration:none;">hello@pulsar.io</a></p>
      <p style="font-size:.75rem;margin-bottom:.4rem;">🐦 &nbsp;<a href="#" style="color:var(--red);text-decoration:none;">@pulsar_io</a></p>
      <p style="font-size:.75rem;">🏢 &nbsp;Austin, TX 78703</p>
    </div>
    <div>
      <div class="side-label">Compliance</div>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
        <div style="background:var(--ink);color:var(--cream);font-size:.55rem;letter-spacing:.08em;padding:.3rem .6rem;">SOC 2 TYPE II</div>
        <div style="background:var(--ink);color:var(--cream);font-size:.55rem;letter-spacing:.08em;padding:.3rem .6rem;">GDPR</div>
        <div style="background:var(--ink);color:var(--cream);font-size:.55rem;letter-spacing:.08em;padding:.3rem .6rem;">CCPA</div>
        <div style="background:var(--ink);color:var(--cream);font-size:.55rem;letter-spacing:.08em;padding:.3rem .6rem;">HIPAA READY</div>
      </div>
    </div>
  </div>
</main>

<!-- NEWSLETTER -->
<div class="nl-banner" id="newsletter">
  <div>
    <div class="nl-label">Weekly Dispatch</div>
    <div class="nl-title">The Pulsar Report — product insights, weekly.</div>
  </div>
  <form class="nl-form" onsubmit="handleNewsletter(event)">
    <input type="email" id="nl-email" placeholder="your@email.com" required>
    <button type="submit">Subscribe →</button>
  </form>
</div>

<!-- FORMS -->
<div class="forms-zone">
  <div class="form-panel" id="contact-form">
    <div class="form-panel-label">Book a Demo</div>
    <h3>Talk to a<br>real human.</h3>
    <p>We'll walk you through the platform, answer your questions, and set up a custom trial around your actual use case. No sales pressure.</p>
    <form onsubmit="handleDemo(event)">
      <div class="field-row">
        <div class="field"><label>First Name *</label><input type="text" placeholder="Ada" required></div>
        <div class="field"><label>Last Name *</label><input type="text" placeholder="Lovelace" required></div>
      </div>
      <div class="field"><label>Work Email *</label><input type="email" placeholder="ada@company.com" required></div>
      <div class="field"><label>Company Name</label><input type="text" placeholder="ACME Corp"></div>
      <div class="field">
        <label>Monthly Sessions (approx.)</label>
        <select>
          <option value="">Select a range</option>
          <option>Under 10,000</option>
          <option>10k – 100k</option>
          <option>100k – 1M</option>
          <option>1M+</option>
        </select>
      </div>
      <div class="field"><label>What are you trying to solve?</label><textarea placeholder="e.g. We're seeing drop-off on our checkout page and can't figure out why..."></textarea></div>
      <div class="check-group">
        <input type="checkbox" id="agree-demo" required>
        <label for="agree-demo">I agree to Pulsar's <a href="#" style="color:var(--red);">Privacy Policy</a> and <a href="#" style="color:var(--red);">Terms of Service</a></label>
      </div>
      <button type="submit" class="btn-submit">Request Demo →</button>
    </form>
  </div>
  <div class="form-panel" id="signup-form">
    <div class="form-panel-label">Free Trial</div>
    <h3>Start in<br>60 seconds.</h3>
    <p>No credit card. No sales call. Drop in the script and watch the data roll in. Cancel any time.</p>
    <form onsubmit="handleSignup(event)">
      <div class="field"><label>Full Name *</label><input type="text" placeholder="Ada Lovelace" required></div>
      <div class="field"><label>Work Email *</label><input type="email" placeholder="ada@company.com" required></div>
      <div class="field"><label>Password *</label><input type="password" placeholder="min. 8 characters" required minlength="8"></div>
      <div class="field"><label>Company Website</label><input type="url" placeholder="https://yoursite.com"></div>
      <div class="field">
        <label>How did you hear about us?</label>
        <select>
          <option value="">Select one</option>
          <option>Twitter / X</option>
          <option>Search</option>
          <option>Product Hunt</option>
          <option>Friend / Colleague</option>
          <option>Podcast</option>
          <option>Newsletter</option>
          <option>Other</option>
        </select>
      </div>
      <div class="check-group">
        <input type="checkbox" id="agree-signup" required>
        <label for="agree-signup">I agree to the <a href="#" style="color:var(--red);">Terms</a> and <a href="#" style="color:var(--red);">Privacy Policy</a></label>
      </div>
      <div class="check-group">
        <input type="checkbox" id="marketing">
        <label for="marketing">Send me tips, case studies, and product updates</label>
      </div>
      <button type="submit" class="btn-submit">Create Free Account →</button>
    </form>
  </div>
</div>

<footer>
  <div class="footer-col footer-brand">
    <div class="logo-main"><em>Pulsar</em></div>
    <p>Behavioral analytics and session intelligence for product teams who care about the truth. Built in Austin, TX.</p>
    <p style="margin-top:1rem;font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;color:var(--red);">© 2026 Pulsar Technologies, Inc.</p>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-col">
    <h5>Product</h5>
    <ul>
      <li><a href="#">Features</a></li><li><a href="#">Pricing</a></li><li><a href="#">Changelog</a></li>
      <li><a href="#">Roadmap</a></li><li><a href="#">Status</a></li><li><a href="#">Security</a></li>
    </ul>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-col">
    <h5>Developers</h5>
    <ul>
      <li><a href="#">Documentation</a></li><li><a href="#">API Reference</a></li><li><a href="#">SDK (npm)</a></li>
      <li><a href="#">Integrations</a></li><li><a href="#">GitHub</a></li>
    </ul>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-col">
    <h5>Company</h5>
    <ul>
      <li><a href="#">About</a></li><li><a href="#">Blog</a></li><li><a href="#">Careers</a></li>
      <li><a href="#">Privacy</a></li><li><a href="#">Terms</a></li><li><a href="#">Press Kit</a></li>
    </ul>
  </div>
</footer>
<div class="footer-bottom">
  <span>SOC 2 TYPE II &nbsp;·&nbsp; GDPR &nbsp;·&nbsp; CCPA &nbsp;·&nbsp; HIPAA READY</span>
  <span>Made with obsession in <span>Austin, TX</span></span>
</div>

<div class="toast" id="toast"></div>

<script>
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3500);
}
function handleDemo(e) { e.preventDefault(); showToast('✓ Demo request received — we\'ll reach out within 2 hours.'); e.target.reset(); }
function handleSignup(e) { e.preventDefault(); showToast('✓ Account created! Check your email to verify.'); e.target.reset(); }
function handleNewsletter(e) { e.preventDefault(); showToast('✓ Subscribed to The Pulsar Report.'); document.getElementById('nl-email').value = ''; }
</script>
<script src="https://collector.sanisilva.site/collector.js"></script>
</body>
</html>
